# Copy to `.env`. Base URL of the backend /ask API.
# Local dev (backend on :8000, frontend on :5173):
VITE_API_BASE=http://localhost:8000

# Leave empty when the frontend and backend are served from the same origin in prod:
# VITE_API_BASE=

# Cloudflare Turnstile SITE key (public). Leave empty in dev -> bot check is
# skipped end-to-end. In prod, set this AND PORTFOLIO_TURNSTILE_SECRET on the
# backend. Get both from the Cloudflare dashboard (Turnstile -> Add site).
VITE_TURNSTILE_SITE_KEY=
